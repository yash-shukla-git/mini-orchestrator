# ── Control Plane ──────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/mini-orchestrator
PORT=3000
HEALTH_CHECK_INTERVAL_MS=10000
NODE_LOST_THRESHOLD_MS=30000
MAX_RESTART_COUNT=5

# ── Worker Node ─────────────────────────────────────────────────────────────────
# Set a different WORKER_PORT for each instance you spin up
WORKER_PORT=3001
WORKER_HOST=localhost
CONTROL_PLANE_URL=http://localhost:3000

# ── CLI ──────────────────────────────────────────────────────────────────────────
# Can also be set per-command with --host
ORCHESTRATOR_URL=http://localhost:3000
